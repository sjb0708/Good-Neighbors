# ─── Neon PostgreSQL ────────────────────────────────────────────────────────
# Get this from your Neon project → Connection Details → Connection string
# Use the POOLED connection string for Vercel serverless.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Created automatically when you add a Blob store in Vercel.
# For local dev: copy from Vercel project → Settings → Environment Variables.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ─── Cookie signing ───────────────────────────────────────────────────────────
# Change this to a long random string in production.
COOKIE_SECRET=change-me-to-a-long-random-secret

# ─── App URL (used in password-reset emails) ─────────────────────────────────
APP_URL=http://localhost:3000
